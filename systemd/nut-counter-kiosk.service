[Unit]
Description=Nut Counter Firefox ESR kiosk
After=nut-counter-backend.service graphical.target
Requires=nut-counter-backend.service

[Service]
Type=simple
User=nut-counter
Group=nut-counter
Environment=HOME=/var/lib/nut-counter
ExecStartPre=/opt/nut-counter/scripts/wait-for-backend.sh http://127.0.0.1:8787/api/status
ExecStart=/usr/bin/firefox-esr --kiosk http://127.0.0.1:8787 --profile /var/lib/nut-counter/firefox-profile
Restart=always
RestartSec=3

[Install]
WantedBy=graphical.target
